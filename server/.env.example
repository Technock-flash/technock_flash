# App
NODE_ENV=development
PORT=4000

# Postgres
DATABASE_URL=postgresql://zimmarket_user:zimmarket_password@localhost:5432/zimmarket_db?schema=public

# JWT
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (when using Docker: set USE_IN_MEMORY_CACHE=false)
REDIS_URL=redis://localhost:6379
# Set to false to use Redis (required when running docker compose for Redis)
USE_IN_MEMORY_CACHE=false

# CORS (comma-separated origins; defaults to CLIENT_URL if unset)
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Auth
BASE_URL=http://localhost:5173
REQUIRE_EMAIL_VERIFICATION=false
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-smtp-user
EMAIL_PASS=your-smtp-pass
EMAIL_FROM="ZimMarket <no-reply@zimmarket.local>"

# Cookie (optional)
COOKIE_REFRESH_TOKEN_NAME=refreshToken
COOKIE_SAME_SITE=lax
COOKIE_REFRESH_MAX_AGE_DAYS=7